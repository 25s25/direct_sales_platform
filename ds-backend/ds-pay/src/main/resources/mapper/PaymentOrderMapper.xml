<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ds.pay.mapper.PaymentOrderMapper">

    <select id="selectByPayOrderNo" resultType="com.ds.pay.entity.PaymentOrder">
        SELECT * FROM ds_payment_order WHERE pay_order_no = #{payOrderNo} LIMIT 1
    </select>

</mapper>
